# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
OWNER_ID=123456789          # ваш Telegram user_id
ADMIN_IDS=123456789         # список id через запятую (можно оставить равным OWNER_ID)

# ─── База данных (PostgreSQL) ─────────────────────────────────────────────────
POSTGRES_USER=shop_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=shop_db
DB_URL=postgresql+asyncpg://shop_user:change_me_in_production@db/shop_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=mli_shop
RABBITMQ_PASS=change_me_in_production
RABBITMQ_URL=amqp://mli_shop:change_me_in_production@rabbitmq:5672/

# ─── Web API ──────────────────────────────────────────────────────────────────
# Bearer-токен для admin API (/api/admin/*)
WEB_ADMIN_KEY=change_me_to_random_secret
# Разрешённые CORS origin через запятую (wildcard * ЗАПРЕЩЁН)
CORS_ORIGINS=http://localhost,http://localhost:8000
# Порт FastAPI (опционально, по умолчанию 8000)
# WEB_API_PORT=8000
# Домен для nginx + Let's Encrypt (production)
TLS_DOMAIN=shop.example.com

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001
ALERTMANAGER_PORT=9094
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# ─── Backup / Restore ─────────────────────────────────────────────────────────
BACKUP_DIR=./backups

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SEC=60

# ─── AI (опционально) ────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OLLAMA_API_KEY=
AI_PROVIDER=groq            # groq | deepseek | ollama
AI_MODEL=                   # оставь пустым — будет использован дефолт провайдера
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_MODEL=deepseek-chat

# ─── Лимиты ──────────────────────────────────────────────────────────────────
AI_CLIENT_START_QUOTA=25
AI_CLIENT_BONUS_QUOTA=5
MAX_PHOTOS_PER_MODEL=10
TIMEZONE=Europe/Moscow
